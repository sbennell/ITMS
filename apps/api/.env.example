# Database connection string for MySQL
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:password@localhost:3306/asset_system"

# Server port
PORT=3001

# Session secret (change this in production!)
# Required when NODE_ENV=production - the server refuses to start without it.
# install.ps1 generates and sets this automatically for production installs.
SESSION_SECRET="your-secret-key-change-in-production"

# Mark the session cookie as Secure (HTTPS-only). Leave unset/false for the default
# plain-HTTP LAN deployment (see install.ps1). Only set to true if you've put this
# app behind HTTPS (e.g. a reverse proxy terminating TLS) - otherwise login will
# appear to succeed but the session cookie won't be sent back by the browser.
COOKIE_SECURE=false
